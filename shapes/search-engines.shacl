@prefix :       <#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix hydra:  <http://www.w3.org/ns/hydra/core#> .
@prefix schema: <http://schema.org/> .

:SearchEnginesShape
  a sh:NodeShape ;
  sh:targetClass schema:ItemList ;

  sh:property [
    sh:path schema:name ;
    sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Topic label" ;
  ] ,
  [
    sh:path schema:itemListElement ;
    sh:node :EngineShape ;
    sh:name "Engines" ;
    sh:description "Search engines in the list. Each row edits one hydra:IriTemplate." ;
  ] .

:EngineShape
  a sh:NodeShape ;
  sh:property [
    sh:path dct:title ;
    sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Title" ;
  ] ,
  [
    sh:path hydra:template ;
    sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "URL template" ;
    sh:description "RFC 6570 template. {query} is substituted with the URI-encoded search term." ;
  ] ,
  [
    sh:path schema:position ;
    sh:datatype xsd:integer ; sh:maxCount 1 ;
    sh:name "Position" ;
    sh:description "Display order (lower first). Used with schema:itemListOrder on the list." ;
  ] .
