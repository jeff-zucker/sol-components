@prefix schema: <http://schema.org/> .
@prefix : <#> .

# Settings for <sol-time>. Each setting is a schema:PropertyValue with
# a schema:name (the label the component dispatches on) and a
# schema:value (the actual value). <#Settings> is the container subject
# the `source` attribute resolves to via its #fragment.
#
# Names in use:
#   "timezone"        — short label for an extra timezone clock
#   "timezone-offset" — that timezone's hour offset from UTC
#
# sol-time always renders local + UTC; adding "timezone" / "timezone-offset"
# adds a third reading. Any HTML attribute on the element overrides the
# matching PropertyValue.

<#Settings>
  schema:additionalProperty <#timezone>, <#timezone-offset> .

<#timezone>
  a schema:PropertyValue ;
  schema:name "timezone"@en ;
  schema:value "mumbai" .

<#timezone-offset>
  a schema:PropertyValue ;
  schema:name "timezone-offset"@en ;
  schema:value 5.5 .
