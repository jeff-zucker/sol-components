@prefix : <#> .
@prefix ui: <http://www.w3.org/ns/ui#> .
@prefix bk: <http://www.w3.org/2002/01/bookmark#> .

# Source list for <sol-search>. Each engine is a ui:Link with a
# bk:recalls value carrying the search-URL prefix (the query is URI-
# encoded onto the end of that prefix). Add an entry by minting a new
# blank-numbered subject under <#SearchEngines>; the ordering in this
# file is the ordering shown in the UI.

<#SearchEngines>
  a bk:Topic ;
  ui:label "Search Engines" .

:e_ddg
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://duckduckgo.com/?q=" ;
  ui:label "DuckDuckGo" .

:e_google
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://www.google.com/search?q=" ;
  ui:label "Google" .

:e_wp
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://en.wikipedia.org/w/index.php?search=" ;
  ui:label "Wikipedia" .

:e_prefix
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://prefix.cc/" ;
  ui:label "prefix.cc" .

:e_lov
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://lov.linkeddata.es/dataset/lov/terms?q=" ;
  ui:label "LOV" .

:e_ety
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://www.etymonline.com/search?q=" ;
  ui:label "Etymology" .

:e_yt
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://www.youtube.com/results?search_query=" ;
  ui:label "YouTube" .

:e_archive
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://web.archive.org/web/*/" ;
  ui:label "Wayback" .

:e_dbpedia
  a ui:Link ;
  bk:hasTopic <#SearchEngines> ;
  bk:recalls "https://dbpedia.org/search?query=" ;
  ui:label "DBpedia" .
