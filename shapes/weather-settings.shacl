@prefix :       <#> .
@prefix swc:    <urn:swc:shape:weather-settings:> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix wd:     <http://www.wikidata.org/entity/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix geo:    <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix schema: <http://schema.org/> .
@prefix time:   <http://www.w3.org/2006/time#> .
@prefix ui:     <http://www.w3.org/ns/ui#> .

<>
  owl:imports <../data/ui-vocab.ttl> .

swc:WeatherSettingsFile
  a rdfs:Class ;
  rdfs:subClassOf wd:Q1193846 .

:WeatherSettingsFileShape
  a sh:NodeShape ;
  sh:targetClass swc:WeatherSettingsFile ;
  sh:property [
    sh:path foaf:primaryTopic ;
    sh:minCount 1 ; sh:maxCount 1 ;
    sh:node :WeatherSettingsShape ;
  ] .

:WeatherSettingsShape
  a sh:NodeShape ;

  sh:property [
    sh:path geo:lat ;
    sh:datatype xsd:decimal ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Latitude" ;
    sh:description "Decimal latitude (-90 to 90)" ;
  ] ,
  [
    sh:path geo:long ;
    sh:datatype xsd:decimal ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Longitude" ;
    sh:description "Decimal longitude (-180 to 180)" ;
  ] ,
  [
    sh:path schema:addressLocality ;
    sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Place" ;
    sh:description "Display name shown on the weather card" ;
  ] ,
  [
    sh:path ui:temperatureUnit ;
    sh:class ui:TemperatureUnit ;
    sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Temperature unit" ;
    sh:description "Fahrenheit, Celsius, or Both" ;
  ] ,
  [
    sh:path time:hours ;
    sh:datatype xsd:integer ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Forecast window (hours)" ;
    sh:description "Max-precipitation lookahead, in hours" ;
  ] .
