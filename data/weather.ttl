@prefix schema: <http://schema.org/> .
@prefix : <#> .

# Settings for <sol-weather>. Each setting is a schema:PropertyValue
# with a schema:name (the label the component dispatches on) and a
# schema:value. <#Settings> is the container subject the `source`
# attribute resolves to via its #fragment.
#
# Names in use:
#   "latitude"         — decimal latitude
#   "longitude"        — decimal longitude
#   "place"            — display name (also used to label the card)
#   "units"            — "metric" | "imperial" | "both"
#   "forecast-window"  — max-precip lookahead, in hours
#
# Coordinates are pinned so the component doesn't depend on the
# Open-Meteo geocoder being reachable. Any HTML attribute on the
# element overrides the matching PropertyValue.

<#Settings>
  schema:additionalProperty
    <#latitude>,
    <#longitude>,
    <#place>,
    <#units>,
    <#forecast-window> .

<#latitude>
  a schema:PropertyValue ;
  schema:name "latitude"@en ;
  schema:value 45.52 .

<#longitude>
  a schema:PropertyValue ;
  schema:name "longitude"@en ;
  schema:value -122.68 .

<#place>
  a schema:PropertyValue ;
  schema:name "place"@en ;
  schema:value "Portland, OR" .

<#units>
  a schema:PropertyValue ;
  schema:name "units"@en ;
  schema:value "both" .

<#forecast-window>
  a schema:PropertyValue ;
  schema:name "forecast-window"@en ;
  schema:value 12 .
