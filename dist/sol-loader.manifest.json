    },
    "cdn": {
      "imports": {
        "rdflib": "https://esm.sh/rdflib@2",
        "dompurify": "https://esm.sh/dompurify@3",
        "ical.js": "https://esm.sh/ical.js@2",
        "marked": "https://esm.sh/marked@4",
        "@comunica/query-sparql": "https://esm.sh/@comunica/query-sparql@5",
        "solid-ui": "https://esm.sh/solid-ui@3",
        "solid-logic": "https://esm.sh/solid-logic@4",
        "@inrupt/solid-client-authn-browser": "https://esm.sh/@inrupt/solid-client-authn-browser@4",
        "n3": "https://esm.sh/n3@2",
        "rdf-validate-shacl": "https://esm.sh/rdf-validate-shacl@0.6",
        "menu-from-rdf": "https://esm.sh/solid-web-components/web/menu-from-rdf.js",
        "sol-accordion": "https://esm.sh/solid-web-components/web/sol-accordion.js",
        "sol-basic": "https://esm.sh/solid-web-components/web/sol-basic.js",
        "sol-breadcrumb": "https://esm.sh/solid-web-components/web/sol-breadcrumb.js",
        "sol-button": "https://esm.sh/solid-web-components/web/sol-button.js",
        "sol-calendar": "https://esm.sh/solid-web-components/web/sol-calendar.js",
        "sol-default": "https://esm.sh/solid-web-components/web/sol-default.js",
        "sol-dropdown-button": "https://esm.sh/solid-web-components/web/sol-dropdown-button.js",
        "sol-feed": "https://esm.sh/solid-web-components/web/sol-feed.js",
        "sol-form": "https://esm.sh/solid-web-components/web/sol-form.js",
        "sol-full": "https://esm.sh/solid-web-components/web/sol-full.js",
        "sol-gallery": "https://esm.sh/solid-web-components/web/sol-gallery.js",
        "sol-include": "https://esm.sh/solid-web-components/web/sol-include.js",
        "sol-live-edit": "https://esm.sh/solid-web-components/web/sol-live-edit.js",
        "sol-loader": "https://esm.sh/solid-web-components/web/sol-loader.js",
        "sol-login": "https://esm.sh/solid-web-components/web/sol-login.js",
        "sol-menu": "https://esm.sh/solid-web-components/web/sol-menu.js",
        "sol-modal": "https://esm.sh/solid-web-components/web/sol-modal.js",
        "sol-pod-extras": "https://esm.sh/solid-web-components/web/sol-pod-extras.js",
        "sol-pod-ops": "https://esm.sh/solid-web-components/web/sol-pod-ops.js",
        "sol-pod": "https://esm.sh/solid-web-components/web/sol-pod.js",
        "sol-query": "https://esm.sh/solid-web-components/web/sol-query.js",
        "sol-rolodex": "https://esm.sh/solid-web-components/web/sol-rolodex.js",
        "sol-search": "https://esm.sh/solid-web-components/web/sol-search.js",
        "sol-settings": "https://esm.sh/solid-web-components/web/sol-settings.js",
        "sol-solidos": "https://esm.sh/solid-web-components/web/sol-solidos.js",
        "sol-tabs": "https://esm.sh/solid-web-components/web/sol-tabs.js",
        "sol-time": "https://esm.sh/solid-web-components/web/sol-time.js",
        "sol-tree-edit": "https://esm.sh/solid-web-components/web/sol-tree-edit.js",
        "sol-wac": "https://esm.sh/solid-web-components/web/sol-wac.js",
        "sol-weather": "https://esm.sh/solid-web-components/web/sol-weather.js",
        "sol-window": "https://esm.sh/solid-web-components/web/sol-window.js",
        "solid-web-components/core/": "https://esm.sh/solid-web-components/core/",
        "solid-web-components/sources/": "https://esm.sh/solid-web-components/sources/",
        "solid-web-components/data/": "https://esm.sh/solid-web-components/data/",
        "solid-web-components/": "https://esm.sh/solid-web-components/web/"
      }
    }
  },
  "capabilities": {
    "auth": {
      "modules": [
        "solid-web-components/core/inrupt-global.js",
        "sol-login"
      ],
      "attributes": []
    },
    "sparql": {
      "modules": [
        "@comunica/query-sparql",
        "sol-query",
        "solid-web-components/core/from-query.js"
      ],
      "attributes": [
        "data-from-query"
      ]
    },
    "rdf": {
      "modules": [
        "solid-logic",
        "solid-ui",
        "sol-tree-edit",
        "sol-form",
        "sol-settings",
        "solid-web-components/core/edit-placements.js",
        "solid-web-components/core/from-rdf.js"
      ],
      "attributes": [
        "data-edit-shape",
        "data-edit-mode",
        "data-subject",
        "data-from-rdf"
      ]
    }
  },
  "interop": {
    "provides": {
      "rdf": {
        "service": "rdf",
        "path": "store"
      },
      "auth": {
        "service": "auth",
        "path": "fetch"
      }
    },
    "consumes": {
      "rdf": {
        "call": "rdf.useStore"
      },
      "auth": {
        "call": "adoptFetch"
      }
    },
    "resource": {
      "emits": {
        "event": "sol-navigate",
        "path": "detail.url"
      },
      "accepts": {
        "selector": "sol-query",
        "attr": "endpoint",
        "transform": "stripHash"
      }
    }
  }
}
