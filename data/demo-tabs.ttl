@prefix ui: <http://www.w3.org/ns/ui#> .
@prefix schema: <http://schema.org/> .

# A <sol-tabs> definition. This is the identical ui:Menu shape <sol-menu>
# consumes — the same document can drive either element. A nested ui:Menu
# (here <#DataGroup>) renders as a tab whose body holds a slimmer
# <sol-tabs variant="sub"> strip of its own children.

<#MainTabs> a ui:Menu; ui:label "demo-tabs" ;
  ui:orientation "horizontal" ;
  ui:parts ( <#Overview> <#DataGroup> <#About> ) .

<#Overview> a ui:Link; ui:label "Overview" ;
  ui:contents "<h2>Overview</h2><p>These tabs were generated from RDF via the <code>from-rdf</code> attribute, using the same <code>ui:Menu</code> vocabulary <code>&lt;sol-menu&gt;</code> uses.</p>" .

<#DataGroup> a ui:Menu; ui:label "Data" ;
  ui:parts ( <#SampleTable> <#SampleTriples> ) .

<#SampleTable> a ui:Component; ui:label "Table" ;
  ui:name "sol-query" ;
  ui:attribute
    [ schema:name "endpoint" ; schema:value <./sample-data.ttl> ] ,
    [ schema:name "sparql" ; schema:value "SELECT ?s ?p ?o WHERE { ?s ?p ?o . }" ] ,
    [ schema:name "view" ; schema:value "table" ] .

<#SampleTriples> a ui:Link; ui:label "Raw triples" ;
  ui:href <./sample-data.ttl> .

<#About> a ui:Link; ui:label "About" ;
  ui:contents "<h2>About</h2><p>The “Data” tab is a nested <code>ui:Menu</code>: <sol-tabs> renders it as a tab whose content is a slimmer sub-tab strip.</p>" .
