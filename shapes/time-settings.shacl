@prefix :       <#> .
@prefix swc:    <urn:swc:shape:time-settings:> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix wd:     <http://www.wikidata.org/entity/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix schema: <http://schema.org/> .

swc:TimeSettingsFile
  a rdfs:Class ;
  rdfs:subClassOf wd:Q1193846 .

:TimeSettingsFileShape
  a sh:NodeShape ;
  sh:targetClass swc:TimeSettingsFile ;
  sh:property [
    sh:path foaf:primaryTopic ;
    sh:minCount 1 ; sh:maxCount 1 ;
    sh:node :TimeSettingsShape ;
  ] .

:TimeSettingsShape
  a sh:NodeShape ;

  sh:property [
    sh:path schema:timezone ;
    sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ;
    sh:name "Extra timezone (IANA name)" ;
    sh:description "An IANA timezone identifier like 'Asia/Kolkata' or 'America/New_York'. sol-time always renders local + UTC; this adds a third clock for the named zone." ;
  ] .
